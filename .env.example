# Copie para .env e preencha. NUNCA commite o .env real.

# Neon Postgres
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"  # pooled (runtime)
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"    # direta (migrations)

# Upstash
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# PSP (Mercado Pago)
PSP_PROVIDER="mercadopago"
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""

# Mailtrap
MAILTRAP_API_TOKEN=""
MAILTRAP_SENDER_EMAIL=""

# Cloudinary (somente imagens públicas de evento)
CLOUDINARY_URL=""

# Cloudflare R2 (arquivos privados: exports, pacotes offline)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# Observabilidade
SENTRY_DSN=""

# URL pública da aplicação (links de ingresso/e-mail)
APP_BASE_URL="http://localhost:3000"
