{
  "name": "ingressos",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @ingressos/db generate",
    "db:migrate": "pnpm --filter @ingressos/db migrate",
    "db:migrate:deploy": "pnpm --filter @ingressos/db exec prisma migrate deploy",
    "db:studio": "pnpm --filter @ingressos/db studio",
    "postinstall": "pnpm --filter @ingressos/db run generate"
  },
  "devDependencies": {
    "turbo": "^2.10.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
