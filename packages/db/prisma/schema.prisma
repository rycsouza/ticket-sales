// Prisma schema — Fase 1 (Fundação): identity, auth, events, inventory, audit.
// Conventions (docs/ARQUITETURA.md §6 / AGENTS.md):
// - every producer-owned business table carries organizationId + index
// - money as Int cents, never Float/Decimal for currency
// - DateTime maps to timestamptz on Postgres; always stored UTC
// - audit table is append-only (no destructive updates — enforced in code,
//   and by revoking UPDATE/DELETE from the runtime db role at hardening)
// - secrets (invite/session tokens) stored as SHA-256 hashes, never raw

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URLs live in prisma.config.ts (Prisma 7)
}

// ---------------------------------------------------------------------------
// Identity & access (EP-01)
// ---------------------------------------------------------------------------

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

model Organization {
  id     String             @id @default(uuid(7))
  status OrganizationStatus @default(ACTIVE)

  // FR-ORG-001: nome, documento, contatos e endereço
  name     String
  document String? // CNPJ/CPF — validated in service layer
  email    String?
  phone    String?

  addressStreet     String?
  addressNumber     String?
  addressComplement String?
  addressDistrict   String?
  addressCity       String?
  addressState      String?
  addressZip        String?

  // FR-ORG-009: identidade pública
  publicName   String?
  supportEmail String?
  supportPhone String?
  logoUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  invites     Invite[]
  events      Event[]
  auditEvents AuditEvent[]
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

model User {
  id     String     @id @default(uuid(7))
  status UserStatus @default(ACTIVE)

  email           String    @unique
  name            String
  // Null until first password is set (e.g. invite not yet accepted).
  // Argon2id hash — never plaintext (FR-AUTH-002).
  passwordHash    String?
  emailVerifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships     Membership[]
  sessions        Session[]
  sentInvites     Invite[]     @relation("InviteInvitedBy")
  acceptedInvites Invite[]     @relation("InviteAcceptedBy")
}

// PRD §8.1 — papéis por organização
enum MembershipRole {
  OWNER
  ADMIN
  EVENT_MANAGER
  FINANCE
  SUPPORT
  GATE_COORDINATOR
  CHECKIN_OPERATOR
  PROMOTER
}

enum MembershipStatus {
  ACTIVE
  SUSPENDED
  REVOKED
}

model Membership {
  id             String           @id @default(uuid(7))
  organizationId String
  userId         String
  role           MembershipRole
  status         MembershipStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  // FR-ORG-006: one membership per user per organization
  @@unique([organizationId, userId])
  @@index([userId])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model Invite {
  id             String         @id @default(uuid(7))
  organizationId String
  email          String
  role           MembershipRole
  status         InviteStatus   @default(PENDING)

  // SHA-256 of the raw token; raw token exists only in the invite e-mail
  tokenHash String   @unique
  // FR-ORG-004: validade e uso único
  expiresAt DateTime

  invitedByUserId  String
  acceptedByUserId String?
  acceptedAt       DateTime?
  revokedAt        DateTime?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  invitedBy    User         @relation("InviteInvitedBy", fields: [invitedByUserId], references: [id])
  acceptedBy   User?        @relation("InviteAcceptedBy", fields: [acceptedByUserId], references: [id])

  @@index([organizationId, status])
  @@index([email])
}

model Session {
  id     String @id @default(uuid(7))
  userId String

  // SHA-256 of the opaque session token (raw token only in the cookie)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?

  ip         String?
  userAgent  String?
  lastUsedAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

// ---------------------------------------------------------------------------
// Events & inventory (EP-02)
// ---------------------------------------------------------------------------

// PRD §11.1
enum EventStatus {
  DRAFT
  PUBLISHED
  SALES_PAUSED
  SALES_CLOSED
  POSTPONED
  CANCELLED
  COMPLETED
  ARCHIVED
}

// DEC-003 — who absorbs the platform fee for the event.
enum FeeMode {
  BUYER // added on top of the buyer's total (service fee)
  PRODUCER // deducted from the producer payout
}

model Event {
  id             String      @id @default(uuid(7))
  organizationId String
  status         EventStatus @default(DRAFT)

  title       String
  slug        String
  description String?
  coverImageUrl String? // Cloudinary — public event images only

  // Venue (embedded for MVP; sectors as separate model)
  venueName    String?
  addressLine  String?
  city         String?
  state        String?

  // Times stored UTC; timezone is the IANA zone used for display
  timezone String  @default("America/Sao_Paulo")
  startsAt DateTime?
  endsAt   DateTime?

  // FR-EVT-003: capacidade total
  capacityTotal Int?

  // FR-EVT-007: janela de vendas
  salesStartAt DateTime?
  salesEndAt   DateTime?

  // FR-EVT-008/009: políticas e termos
  ageRating          String?
  cancellationPolicy String?
  eventTerms         String?

  // FR-EVT-012: limites por pedido/comprador (regra detalhada no serviço)
  maxTicketsPerOrder Int?

  // DEC-003: platform fee, configurable per event. Basis points over the
  // ticket value (after discount). feeMode decides who absorbs it.
  platformFeeBps Int     @default(0)
  feeMode        FeeMode @default(PRODUCER)

  publishedAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  sectors      Sector[]
  ticketTypes  TicketType[]
  salesBatches SalesBatch[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
}

model Sector {
  id             String @id @default(uuid(7))
  organizationId String
  eventId        String

  name     String
  // FR-EVT-003: capacidade opcional por setor (sem assentos numerados)
  capacity Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event       Event        @relation(fields: [eventId], references: [id])
  ticketTypes TicketType[]

  @@unique([eventId, name])
  @@index([organizationId])
}

// FR-EVT-013: inteiro, meia, promocional, cortesia e personalizadas
enum TicketTypeKind {
  FULL
  HALF
  PROMOTIONAL
  COURTESY
  CUSTOM
}

model TicketType {
  id             String         @id @default(uuid(7))
  organizationId String
  eventId        String
  sectorId       String?
  kind           TicketTypeKind
  active         Boolean        @default(true)

  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event        Event        @relation(fields: [eventId], references: [id])
  sector       Sector?      @relation(fields: [sectorId], references: [id])
  salesBatches SalesBatch[]

  @@unique([eventId, name])
  @@index([organizationId])
}

enum SalesBatchStatus {
  SCHEDULED
  OPEN
  CLOSED
  SOLD_OUT
}

model SalesBatch {
  id             String           @id @default(uuid(7))
  organizationId String
  eventId        String
  ticketTypeId   String
  status         SalesBatchStatus @default(SCHEDULED)

  name String

  // BR-FIN-001: money as integer cents
  priceCents Int

  // Inventory counters — mutated ONLY via atomic conditional updates
  // (ARQUITETURA §8). available = quantityTotal - quantitySold - quantityReserved
  quantityTotal    Int
  quantitySold     Int @default(0)
  quantityReserved Int @default(0)

  // FR-INV-002/003: janela de venda; abertura/encerramento automáticos
  salesStartAt DateTime?
  salesEndAt   DateTime?

  maxPerOrder Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event      Event      @relation(fields: [eventId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  @@index([organizationId])
  @@index([eventId, status])
}

// ---------------------------------------------------------------------------
// Audit (EP-12) — append-only
// ---------------------------------------------------------------------------

model AuditEvent {
  id String @id @default(uuid(7))

  // Nullable: platform-level actions have no organization scope
  organizationId String?
  actorUserId    String?
  // e.g. "user" | "system" | "platform_admin" — free-form label for non-user actors
  actorType      String  @default("user")

  // FR-AUD-002: ator, organização, recurso, ação, data/hora, origem, justificativa
  action        String
  resourceType  String
  resourceId    String?
  justification String?

  // FR-AUD-003: valor anterior/posterior (sensitive fields redacted by caller)
  before Json?
  after  Json?

  correlationId String
  ip            String?

  createdAt DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([resourceType, resourceId])
  @@index([actorUserId, createdAt])
}

// ---------------------------------------------------------------------------
// Sales engine — Fase 2 (EP-03/04/05)
// ---------------------------------------------------------------------------

enum ReservationStatus {
  ACTIVE
  CONFIRMED
  RELEASED
  EXPIRED
}

// FR-INV-005/006/007 — temporary hold on batch units. Counters live on
// SalesBatch and are mutated ONLY via atomic conditional SQL (ARQUITETURA §8).
model InventoryReservation {
  id             String            @id @default(uuid(7))
  organizationId String
  eventId        String
  batchId        String
  orderId        String?
  status         ReservationStatus @default(ACTIVE)
  quantity       Int
  expiresAt      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, expiresAt])
  @@index([orderId])
  @@index([organizationId, batchId])
}

// PRD §11.2
enum OrderStatus {
  CREATED
  AWAITING_PAYMENT
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  EXPIRED
  CANCELLED
  CHARGEBACK
}

model Order {
  id             String      @id @default(uuid(7))
  organizationId String
  eventId        String
  status         OrderStatus @default(CREATED)

  // Public, non-sequential lookup code (never the uuid) — FR-CHK-017
  code String @unique

  buyerName     String
  buyerEmail    String
  buyerDocument String?
  buyerPhone    String?

  // BR-FIN-001: integer cents; totals computed SERVER-SIDE only
  subtotalCents Int
  discountCents Int @default(0)
  // Platform fee snapshot (DEC-003). In BUYER mode it is included in
  // totalCents; in PRODUCER mode it is recorded but not charged to the buyer.
  feeCents      Int     @default(0)
  feeMode       FeeMode @default(PRODUCER)
  totalCents    Int

  // Payment deadline — mirrors the inventory reservation expiry
  expiresAt   DateTime?
  paidAt      DateTime?
  cancelledAt DateTime?
  refundedAt  DateTime?

  correlationId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    OrderItem[]
  payments Payment[]

  @@index([organizationId, status])
  @@index([organizationId, eventId])
  @@index([buyerEmail])
  @@index([status, expiresAt])
}

// One row per UNIT (PRD §13.1) — each item becomes exactly one ticket.
model OrderItem {
  id             String @id @default(uuid(7))
  organizationId String
  orderId        String
  eventId        String
  batchId        String
  ticketTypeId   String

  unitPriceCents Int

  createdAt DateTime @default(now())

  order  Order   @relation(fields: [orderId], references: [id])
  ticket Ticket?

  @@index([orderId])
  @@index([organizationId, batchId])
}

// PRD §11.3
enum PaymentStatus {
  CREATED
  PROCESSING
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
  PARTIALLY_REFUNDED
  REFUNDED
  DISPUTED
  CHARGED_BACK
}

enum PaymentMethod {
  PIX
  CARD
}

model Payment {
  id             String        @id @default(uuid(7))
  organizationId String
  orderId        String
  provider       String
  method         PaymentMethod
  status         PaymentStatus @default(CREATED)

  amountCents Int

  providerTransactionId String? @unique
  // FR-PAY-004: every charge creation is idempotent
  idempotencyKey        String  @unique

  pixQrCode     String?
  pixQrCodeText String?
  expiresAt     DateTime?

  providerFeeCents Int?
  approvedAt       DateTime?
  refundedAt       DateTime?

  correlationId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([organizationId, status])
}

enum PaymentEventStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

// FR-PAY-006: webhooks persisted BEFORE processing; unique provider event id
// makes duplicated deliveries harmless.
model PaymentEvent {
  id       String             @id @default(uuid(7))
  provider String
  status   PaymentEventStatus @default(RECEIVED)

  providerEventId       String  @unique
  providerTransactionId String?
  type                  String

  payload Json
  error   String?

  correlationId String

  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  @@index([status, receivedAt])
}

// PRD §11.4 (transfer returns to VALID — it is not a resting state)
enum TicketStatus {
  PENDING_ISSUE
  VALID
  CHECKED_IN
  BLOCKED
  CANCELLED
  REFUNDED
}

model Ticket {
  id             String       @id @default(uuid(7))
  organizationId String
  eventId        String
  orderId        String
  // Unique: retrying emission can never duplicate a ticket (FR-TKT-016)
  orderItemId    String       @unique
  ticketTypeId   String
  status         TicketStatus @default(VALID)

  // SHA-256 of the QR/access token; the raw token exists only in the
  // buyer's link/e-mail (FR-TKT-002/003). Transfer regenerates it.
  tokenHash String @unique

  participantName  String?
  participantEmail String?

  issuedAt    DateTime  @default(now())
  checkedInAt DateTime?
  blockedAt   DateTime?
  cancelledAt DateTime?

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@index([organizationId, eventId, status])
  @@index([orderId])
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id             String             @id @default(uuid(7))
  organizationId String?
  status         NotificationStatus @default(PENDING)

  type      String
  recipient String
  subject   String?

  attempts          Int     @default(0)
  lastError         String?
  providerMessageId String?

  orderId  String?
  ticketId String?

  correlationId String

  createdAt DateTime  @default(now())
  sentAt    DateTime?

  @@index([status, attempts])
}

// ARQUITETURA §7 — durable idempotency for externally-visible effects.
model IdempotencyKey {
  key    String @id
  scope  String
  result Json?

  createdAt DateTime @default(now())

  @@index([scope, createdAt])
}

// ---------------------------------------------------------------------------
// Promoters, coupons & commissions — Fase 3 (EP-06)
// ---------------------------------------------------------------------------

// PERCENT stores basis points (1% = 100); FIXED stores integer cents.
enum CommissionType {
  PERCENT
  FIXED
}

// Base amount the commission is computed from (BR-PRM-005).
enum CommissionBase {
  NOMINAL // gross unit price
  AFTER_DISCOUNT // unit price after its share of the order discount
}

enum CouponType {
  PERCENT // basis points
  FIXED // integer cents, applied to the whole order
}

// How a sale was attributed to a promoter (FR-PRM-007, BR-PRM-002).
enum AttributionMechanism {
  NONE
  LINK
  COUPON
}

// CommissionEntry is append-only: money moves via ACCRUAL / REVERSAL rows with
// signed amounts. A reversal is a compensating entry, never an UPDATE/DELETE.
enum CommissionEntryType {
  ACCRUAL
  REVERSAL
}

// FR-PRM-003 — a promoter (Membership with role PROMOTER) is bound to specific
// events; only assigned events attribute sales to them.
model PromoterAssignment {
  id             String  @id @default(uuid(7))
  organizationId String
  eventId        String
  membershipId   String
  active         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, membershipId])
  @@index([organizationId, eventId])
  @@index([membershipId])
}

// FR-PRM-004 — one trackable link per promoter per event. `code` is a short,
// non-guessable public ref carried in the landing URL (?p=CODE).
model PromoterLink {
  id             String  @id @default(uuid(7))
  organizationId String
  eventId        String
  membershipId   String
  code           String  @unique
  active         Boolean @default(true)
  clickCount     Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, membershipId])
  @@index([organizationId, eventId])
  @@index([membershipId])
}

// FR-PRM-005 / FR-CHK-008 — individual (membershipId set) or shared coupon.
// `code` is stored uppercased; unique within the event.
model Coupon {
  id             String     @id @default(uuid(7))
  organizationId String
  eventId        String
  code           String
  type           CouponType
  value          Int
  active         Boolean    @default(true)

  membershipId String? // owning promoter, if individual

  startsAt       DateTime?
  endsAt         DateTime?
  maxRedemptions Int?
  redemptions    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, code])
  @@index([organizationId, eventId])
}

// FR-PRM-008/009/015, BR-PRM-006 — versioned commission rule. A change creates
// a NEW row and supersedes the previous one; past accruals snapshot their rule
// so they never recompute retroactively. Resolution picks the most specific
// active rule (membership+ticketType > membership > ticketType > event).
model CommissionRule {
  id             String         @id @default(uuid(7))
  organizationId String
  eventId        String
  membershipId   String? // narrows to one promoter
  ticketTypeId   String? // narrows to one ticket type
  type           CommissionType
  value          Int
  base           CommissionBase @default(NOMINAL)
  active         Boolean        @default(true)

  supersededAt DateTime?
  createdAt    DateTime  @default(now())

  @@index([organizationId, eventId, active])
  @@index([eventId, membershipId, active])
}

// FR-CHK-009/010, FR-PRM-007, BR-PRM-001 — attribution captured at checkout and
// persisted with its origin. One row per order.
model OrderAttribution {
  id             String               @id @default(uuid(7))
  organizationId String
  orderId        String               @unique
  eventId        String
  mechanism      AttributionMechanism @default(NONE)
  membershipId   String? // attributed promoter
  couponId       String?
  linkId         String?

  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  capturedAt DateTime @default(now())

  @@index([organizationId, eventId])
  @@index([membershipId])
}

// FR-FIN-001/002/007 — append-only financial ledger. Never UPDATE/DELETE;
// corrections are compensating entries. Three accounts let reports be
// reproduced from the entries (NFR-REL-006):
//   PRODUCER  — what the platform owes the producer (payout base)
//   PLATFORM  — the platform's own revenue net of PSP cost
//   PROMOTER  — commission owed to promoters
enum LedgerAccount {
  PRODUCER
  PLATFORM
  PROMOTER
}

enum LedgerEntryType {
  SALE // gross ticket value before discount (producer credit)
  DISCOUNT // coupon discount (producer debit)
  FEE // platform fee (platform credit; producer debit in PRODUCER mode)
  PSP_COST // payment provider cost (platform debit)
  COMMISSION // promoter commission (promoter credit; producer debit)
  REFUND // reversal on refund/chargeback (compensating)
  PAYOUT // externally executed payout registered (FR-FIN-013)
  ADJUSTMENT // manual compensating correction
}

model LedgerEntry {
  id             String          @id @default(uuid(7))
  organizationId String
  eventId        String
  orderId        String?
  account        LedgerAccount
  type           LedgerEntryType
  // Signed integer cents: credits positive, debits negative. Account balance
  // is the plain SUM of amountCents.
  amountCents    Int
  // Owning promoter for PROMOTER/COMMISSION entries.
  membershipId   String?
  memo           String?

  correlationId String
  createdAt     DateTime @default(now())

  // Idempotency for automatic postings: one (orderId, account, type) row.
  // PAYOUT/ADJUSTMENT have no orderId and are inserted explicitly (not guarded).
  @@unique([orderId, account, type])
  @@index([organizationId, eventId])
  @@index([organizationId, account])
  @@index([membershipId])
}

// Check-in / portaria (EP-09) — Fase 6
// ---------------------------------------------------------------------------

enum CheckinMode {
  ONLINE
  OFFLINE
}

// FR-CIN-001/002 — operators bound to an event (optionally a sector/gate).
model CheckinAssignment {
  id             String  @id @default(uuid(7))
  organizationId String
  eventId        String
  membershipId   String
  sectorId       String?
  active         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, membershipId])
  @@index([organizationId, eventId])
  @@index([membershipId])
}

// FR-CIN-005 — one successful check-in per ticket. The unique(ticketId) is the
// dedup/idempotency guard (FR-CIN-006/013/017): a second attempt cannot create
// a second admission. Undo deletes the row (audited) so re-entry is possible.
model Checkin {
  id                   String      @id @default(uuid(7))
  organizationId       String
  eventId              String
  ticketId             String      @unique
  operatorMembershipId String
  deviceId             String?
  mode                 CheckinMode @default(ONLINE)
  manual               Boolean     @default(false)
  justification        String?

  checkedInAt DateTime
  syncedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([organizationId, eventId])
}

// CRM (EP-08) — consolidated buyer base per organization. Identity + consent
// live here; purchase aggregates are derived from paid orders (reproducible).
model Customer {
  id             String  @id @default(uuid(7))
  organizationId String
  email          String
  name           String?
  phone          String?
  document       String?

  // FR-CRM-002/008 — consent + opt-out (LGPD). Consent captured at checkout.
  optedOut       Boolean   @default(false)
  consentVersion String?
  consentAt      DateTime?
  consentOrigin  String?

  // DEC-010 (LGPD retention): drives anonymization of inactive buyers.
  lastPurchaseAt DateTime?
  anonymizedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([anonymizedAt, lastPurchaseAt])
}

// FR-ADM-009 — internal support notes on an order. Never exposed to the buyer.
model OrderNote {
  id             String @id @default(uuid(7))
  organizationId String
  orderId        String
  authorUserId   String
  body           String

  createdAt DateTime @default(now())

  @@index([organizationId, orderId])
}

// FR-PRM-010/011, BR-PRM-004 — append-only commission ledger. Commission is
// due only on paid, non-refunded, eligible items; refund/chargeback posts a
// REVERSAL. `ruleSnapshot` keeps each entry reproducible.
model CommissionEntry {
  id             String              @id @default(uuid(7))
  organizationId String
  eventId        String
  membershipId   String
  orderId        String
  type           CommissionEntryType

  quantity    Int
  baseCents   Int
  amountCents Int // signed: +accrual, -reversal

  ruleSnapshot Json

  correlationId String
  createdAt     DateTime @default(now())

  // Exactly one ACCRUAL and one REVERSAL per order → idempotent hooks.
  @@unique([orderId, type])
  @@index([organizationId, eventId, membershipId])
  @@index([membershipId, createdAt])
}
